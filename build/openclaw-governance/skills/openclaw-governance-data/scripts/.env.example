# OpenClaw Backup 环境变量配置示例
# 复制此文件到 ~/.openclaw/.env 并修改

# ============================================
# 备份配置
# ============================================

# 本地备份目录（默认：~/Workspaces/openclaw.bak）
OPENCLAW_BACKUP_WORKSPACE=~/Workspaces/openclaw.bak

# 云盘备份目录（默认：~/Cloud/OneDrivePersonal/OpenClaw）
# 支持 OneDrive、iCloud、Dropbox 等
OPENCLAW_CLOUD_WORKSPACE=~/Cloud/OneDrivePersonal/OpenClaw

# 工作空间（默认：~/Workspaces/openclaw/main）
OPENCLAW_LOCAL_WORKSPACE=~/Workspaces/openclaw/main

# ============================================
# 使用说明
# ============================================
# 
# 1. 本地备份
#    ./scripts/backup.sh
#    → 备份到 $OPENCLAW_BACKUP_WORKSPACE
#
# 2. 云盘备份
#    ./scripts/cloud_backup.sh
#    → 备份到 $OPENCLAW_CLOUD_WORKSPACE
#    → OneDrive 自动同步到云端
#
# 3. GitHub 备份
#    ./scripts/github_backup.sh
#    → 提交并推送到远程仓库
#
# 4. 安全删除
#    ./scripts/safe_delete.sh <file>
#    → 删除前自动备份
#
# 5. 恢复文件
#    ./scripts/restore_deleted.sh <file>
#    → 从备份恢复
#